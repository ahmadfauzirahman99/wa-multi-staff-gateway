# ============================================================
#  WhatsApp Multi-Staff Gateway — Environment Variables
#  Copy to .env and fill in your values
# ============================================================

# Server
PORT=3030

# Database (MySQL / MariaDB)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=simrs_wa

# Security
# Set API_KEY to protect all /api/* endpoints (except /api/health)
# Leave empty to disable auth (development only — never leave empty in production)
API_KEY=

# Cron token — required to call /api/run-cron
CRON_TOKEN=change-this-to-a-strong-secret

# Webhook
# POST incoming messages & delivery ACKs to this URL
# Leave empty to disable
WEBHOOK_URL=

# Queue processor settings
MAX_RETRY=3
QUEUE_DELAY_MIN=2000
QUEUE_DELAY_MAX=5000

# Auto-reply (set to true to enable)
AUTO_REPLY_ENABLED=false
AUTO_BOT_AI_ENABLED=false

# Misc
CHAT_LOG_FILE=chats-log.jsonl
